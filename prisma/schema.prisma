generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model capture_requests {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guest_session_id String         @db.Uuid
  url              String
  status           capture_status @default(pending)
  error_message    String?
  requested_at     DateTime       @default(now()) @db.Timestamptz(6)
  completed_at     DateTime?      @db.Timestamptz(6)
  guest_sessions   guest_sessions @relation(fields: [guest_session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  screenshots      screenshots[]

  @@index([guest_session_id], map: "idx_capture_requests_session")
  @@index([status], map: "idx_capture_requests_status")
}

model guest_sessions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ip_address       String             @unique @db.Inet
  tries_used       Int                @default(0) @db.SmallInt
  is_blocked       Boolean            @default(false)
  first_seen_at    DateTime           @default(now()) @db.Timestamptz(6)
  last_seen_at     DateTime           @default(now()) @db.Timestamptz(6)
  capture_requests capture_requests[]

  @@index([ip_address], map: "idx_guest_sessions_ip")
}

model screenshots {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capture_request_id String           @db.Uuid
  r2_object_key      String
  r2_bucket_name     String           @default("website-capture")
  file_size_bytes    Int?
  captured_at        DateTime         @default(now()) @db.Timestamptz(6)
  capture_requests   capture_requests @relation(fields: [capture_request_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum capture_status {
  pending
  processing
  completed
  failed
}
